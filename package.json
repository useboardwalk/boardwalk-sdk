{
  "name": "@useboardwalk/sdk",
  "version": "0.4.0",
  "description": "Framework-agnostic SDK + CLI for building unsigned Boardwalk transactions (launch, contribute, claim, refund, presale seed, BMX stake/unstake, fee/vesting/participation claims, LP, swap, visibility, vote).",
  "license": "MIT",
  "author": "Boardwalk",
  "homepage": "https://www.useboardwalk.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useboardwalk/boardwalk-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/useboardwalk/boardwalk-sdk/issues"
  },
  "keywords": [
    "boardwalk",
    "erc-8021",
    "base",
    "viem",
    "agent",
    "non-custodial",
    "token-launch",
    "defi"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "boardwalk": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "skills",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli.ts",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ox": "0.14.7",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
